{
  "name": "@kanishka-namdeo/electron-mcp-server",
  "version": "1.0.1",
  "description": "MCP server for testing Electron applications using Playwright",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "electron-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:unit": "vitest run tests/unit/**/*.test.ts",
    "test:integration": "vitest run tests/integration/**/*.test.ts",
    "test:e2e": "vitest run tests/e2e/**/*.test.ts",
    "test:compliance": "vitest run tests/compliance/**/*.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:setup": "tsx tests/e2e/setup.ts setup",
    "test:cleanup": "tsx tests/e2e/setup.ts cleanup",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "electron",
    "playwright",
    "testing",
    "automation",
    "cdp",
    "chrome-devtools-protocol",
    "e2e-testing",
    "ui-testing",
    "cursor",
    "claude",
    "ai-tools"
  ],
  "author": "Kanishka Namdeo <kanishka.namdeo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/kanishka-namdeo/electron-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kanishka-namdeo/electron-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/kanishka-namdeo/electron-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pino": "^9.0.0",
    "playwright": "^1.48.0",
    "uuid": "^10.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
